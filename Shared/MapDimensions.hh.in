#pragma once

// Generated by Shared/MapDims.cmake at CMake configure time. The values are
// derived from Map/main/main.tmj's width × tilewidth and height × tileheight
// and serve as the initial value for the runtime ARENA_WIDTH / ARENA_HEIGHT
// globals below. TiledMap::load() overwrites the runtime values from whatever
// .tmj it actually reads at startup, so swapping the embedded/loaded map
// reshapes the arena without recompiling.

#include <cstdint>

inline uint32_t const INITIAL_ARENA_WIDTH  = @GARDN_ARENA_WIDTH@;
inline uint32_t const INITIAL_ARENA_HEIGHT = @GARDN_ARENA_HEIGHT@;

extern uint32_t ARENA_WIDTH;
extern uint32_t ARENA_HEIGHT;
